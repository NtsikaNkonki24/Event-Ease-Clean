@{
    ViewData["Title"] = "Home Page";
}

<div class="bg-primary text-white rounded-4 p-5 mb-5 text-center shadow">

    <h1 class="display-3 fw-bold">
        🎉 EventEase
    </h1>

    <p class="lead">
        Manage venues, events and bookings from one central platform.
    </p>

</div>

<div class="row g-4">

    <div class="col-md-4">

        <div class="card h-100 shadow-sm border-0">

            <div class="card-body text-center">

                <h1>🏢</h1>

                <h3 class="mt-3">Venues</h3>

                <p>
                    Create and manage venue information, locations and images.
                </p>

                <a asp-controller="Venues"
                   asp-action="Index"
                   class="btn btn-primary">
                    Manage Venues
                </a>

            </div>

        </div>

    </div>

    <div class="col-md-4">

        <div class="card h-100 shadow-sm border-0">

            <div class="card-body text-center">

                <h1>🎉</h1>

                <h3 class="mt-3">Events</h3>

                <p>
                    Create, organise and manage events linked to venues.
                </p>

                <a asp-controller="Events"
                   asp-action="Index"
                   class="btn btn-success">
                    Manage Events
                </a>

            </div>

        </div>

    </div>

    <div class="col-md-4">

        <div class="card h-100 shadow-sm border-0">

            <div class="card-body text-center">

                <h1>📅</h1>

                <h3 class="mt-3">Bookings</h3>

                <p>
                    View and track customer bookings and attendance records.
                </p>

                <a asp-controller="Bookings"
                   asp-action="Index"
                   class="btn btn-info text-white">
                    Manage Bookings
                </a>

            </div>

        </div>

    </div>

</div>