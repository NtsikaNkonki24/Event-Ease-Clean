@model Event_Ease_2026_Ntsika_Nkonki.Models.Booking

<h2>Booking Details</h2>

<div>
    <p><strong>Customer:</strong> @Model.CustomerName</p>
    <p><strong>Seats:</strong> @Model.SeatsBooked</p>
    <p><strong>Date:</strong> @Model.BookingDate.ToShortDateString()</p>
    <p><strong>Event:</strong> @Model.Event?.Name</p>
    <p><strong>Venue:</strong> @Model.Venue?.Name</p>
</div>

<a asp-action="Edit" asp-route-id="@Model.BookingId" class="btn btn-primary">Edit</a>
<a asp-action="Index" class="btn btn-secondary">Back to List</a>

