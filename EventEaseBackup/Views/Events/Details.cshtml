@model Event_Ease_2026_Ntsika_Nkonki.Models.Event

<h2>Event Details</h2>

<div>
    <h4>@Model.Name</h4>
    <p><strong>Date:</strong> @Model.Date.ToShortDateString()</p>
    <p><strong>Venue:</strong> @Model.Venue?.Name</p>
    @if (!string.IsNullOrEmpty(Model.ImageUrl))
    {
        <img src="@Model.ImageUrl" width="200" />
    }
</div>

<a asp-action="Edit" asp-route-id="@Model.EventId" class="btn btn-primary">Edit</a>
<a asp-action="Index" class="btn btn-secondary">Back to List</a>
