@model Event_Ease_2026_Ntsika_Nkonki.Models.Venue

<div class="container mt-4">

    <div class="card shadow-sm border-0">
        <div class="card-header bg-primary text-white">
            <h4 class="mb-0">Create Venue</h4>
        </div>

        <div class="card-body">

            <!-- Validation Summary -->
            <div asp-validation-summary="All" class="alert alert-danger"></div>

            <form asp-action="Create" method="post" enctype="multipart/form-data">

                <div class="row">

                    <!-- Name -->
                    <div class="col-md-6 mb-3">
                        <label asp-for="Name" class="form-label fw-semibold"></label>
                        <input asp-for="Name" class="form-control" placeholder="Enter venue name" />
                        <span asp-validation-for="Name" class="text-danger"></span>
                    </div>

                    <!-- Location -->
                    <div class="col-md-6 mb-3">
                        <label asp-for="Location" class="form-label fw-semibold"></label>
                        <input asp-for="Location" class="form-control" placeholder="Enter location" />
                        <span asp-validation-for="Location" class="text-danger"></span>
                    </div>

                    <!-- Capacity -->
                    <div class="col-md-6 mb-3">
                        <label asp-for="Capacity" class="form-label fw-semibold"></label>
                        <input asp-for="Capacity" type="number" class="form-control" placeholder="e.g. 500" />
                        <span asp-validation-for="Capacity" class="text-danger"></span>
                    </div>

                    <!-- Image Upload -->
                    <div class="col-md-6 mb-3">
                        <label class="form-label fw-semibold">Venue Image</label>
                        <input type="file" name="imageFile" class="form-control" accept="image/*" />
                        <small class="text-muted">Upload a clear image of the venue.</small>
                    </div>

                </div>

                <!-- Buttons -->
                <div class="d-flex justify-content-between mt-3">

                    <a asp-action="Index" class="btn btn-outline-secondary">
                        ← Back
                    </a>

                    <button type="submit" class="btn btn-success px-4">
                        Save Venue
                    </button>

                </div>

            </form>

        </div>
    </div>
</div>

@section Scripts {
    <partial name="_ValidationScriptsPartial" />
}