@model IEnumerable<Event_Ease_2026_Ntsika_Nkonki.Models.Booking>

@if (TempData["NewBookingId"] != null)
{
    <div class="alert alert-success alert-dismissible fade show" role="alert">
        Booking created successfully! Your Booking ID is
        <strong>@TempData["NewBookingId"]</strong>.
        <button type="button" class="btn-close" data-bs-dismiss="alert" aria-label="Close"></button>
    </div>
}


<h2>Bookings</h2>
<a asp-action="Create" class="btn btn-success">Add Booking</a>

<form asp-action="Index" method="get" class="mb-3">
    <div class="input-group">
        <input type="text" name="searchString" value="@ViewData["CurrentFilter"]"
               class="form-control" placeholder="Search by Booking ID or Event Name" />
        <button type="submit" class="btn btn-primary">Search</button>
    </div>
</form>

<table class="table">
    <thead>
        <tr>
            <th>Customer</th>
            <th>Seats</th>
            <th>Event</th>
            <th>Venue</th>
            <th>Date</th>
            <th>Actions</th>
        </tr>
    </thead>
    <tbody>
        @foreach (var item in Model)
        {
            <tr>
                <td>@item.CustomerName</td>
                <td>@item.SeatsBooked</td>
                <td>@item.Event?.Name</td>
                <td>@item.Venue?.Name</td>
                <td>@item.BookingDate.ToShortDateString()</td>
                <td>
                    <a asp-action="Edit" asp-route-id="@item.BookingId">Edit</a> |
                    <a asp-action="Details" asp-route-id="@item.BookingId">Details</a> |
                    <a asp-action="Delete" asp-route-id="@item.BookingId">Delete</a>
                </td>
            </tr>
        }
    </tbody>
</table>

